# העתק ל-.env ומלא. רק GEMINI_API_KEY חובה.

# מפתח Gemini חינמי מ-https://aistudio.google.com/apikey
GEMINI_API_KEY=

# מודל (ברירת מחדל gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# כתובת בסיס ציבורית של ה-backend (לבניית קישור הווידאו).
# מקומי במחשב: http://localhost:8000
# לגישה מהטלפון באותו WiFi: http://<LAN_IP>:8000
PUBLIC_BASE_URL=http://localhost:8000

# אופציונלי: אם ffmpeg/ffprobe לא ב-PATH, ציין נתיב מלא.
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# אופציונלי: Unsplash fallback (אם ריק - מדולג, ויקיפדיה בלבד).
UNSPLASH_ACCESS_KEY=

# קאש תוכן קבוע ב-Supabase (תסריטים, נקודות מרכזיות, חידונים).
# אם ריק - הקאש כבוי והכל עובד כרגיל (רק בלי חיסכון בטוקנים).
# SUPABASE_URL: כתובת הפרויקט (https://xxxx.supabase.co)
# SUPABASE_SERVICE_KEY: ה-service_role key (Project Settings -> API).
#   סוד! לשמור רק כאן וב-secrets של HuggingFace Space - לעולם לא בצד לקוח.
# לפני ההפעלה: להריץ את supabase/migrations/0005_script_cache.sql ב-SQL Editor.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
