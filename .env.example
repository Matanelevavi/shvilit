# העתק קובץ זה ל-.env ומלא את הערכים מ-Supabase (Project Settings -> API).
# שני הערכים האלה הם ציבוריים בכוונה (anon key מוגן על ידי Row Level Security).
# מפתח Gemini *אינו* נמצא כאן - הוא סוד בצד השרת ב-Supabase (ראה README).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# אופציונלי: כפיית ספק LLM. ערכים: "mock" | "edge" | "auto" (ברירת מחדל auto).
# auto = edge אם הוגדר Supabase, אחרת mock.
EXPO_PUBLIC_LLM_PROVIDER=auto

# כתובת backend הווידאו (FastAPI). מקומי: http://localhost:8000
# לטלפון באותו WiFi: http://<LAN_IP>:8000
EXPO_PUBLIC_VIDEO_API_URL=http://localhost:8000
